{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ts-node",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "ts-node",
            "runtimeArgs": [
                "--transpile-only"
            ],
            "program": "index.ts",
            "cwd": "${workspaceRoot}",
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**",
                "node_modules/**"
            ]
        }
    ]
}